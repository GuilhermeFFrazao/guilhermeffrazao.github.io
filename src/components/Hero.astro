---
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>

  <div class="container hero-inner">
    <p class="hero-badge" data-hero="badge">
      <span class="pulse" aria-hidden="true"></span>
      Open to opportunities · Lisbon, Portugal
    </p>

    <h1 class="hero-name">
      <span class="line" data-hero="line"><span class="line-inner">Guilherme</span></span>
      <span class="line" data-hero="line"><span class="line-inner accent-text">Frazão</span></span>
    </h1>

    <p class="hero-tagline" data-hero="fade">
      Software engineer building <strong>AI&#8209;powered solutions</strong>.
    </p>

    <p class="hero-sub" data-hero="fade">
      MSc Computer Science student at NOVA School of Science and Technology,
      currently researching multi&#8209;modal RAG systems.
    </p>

    <div class="hero-cta" data-hero="fade">
      <a class="btn btn-primary" href="#work">View my work</a>
      <a class="btn" href="#contact">Get in touch</a>
    </div>
  </div>

  <a class="scroll-cue" href="#work" aria-label="Scroll to work" data-hero="fade">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 4v16m0 0 6-6m-6 6-6-6" />
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: clip;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.5;
  }
  .glow-1 {
    width: 55vw;
    height: 55vw;
    top: -20%;
    right: -15%;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.28), transparent 65%);
    animation: drift 14s ease-in-out infinite alternate;
  }
  .glow-2 {
    width: 40vw;
    height: 40vw;
    bottom: -25%;
    left: -10%;
    background: radial-gradient(circle, rgba(96, 165, 250, 0.14), transparent 65%);
    animation: drift 18s ease-in-out infinite alternate-reverse;
  }
  @keyframes drift {
    to {
      transform: translate(-6%, 8%) scale(1.1);
    }
  }

  .hero-inner {
    padding-block: 8rem 4rem;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.45em 1.1em;
    background: rgba(255, 255, 255, 0.02);
    margin-bottom: 2.2rem;
  }
  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.6);
    animation: pulse 2.2s infinite;
  }
  @keyframes pulse {
    70% {
      box-shadow: 0 0 0 9px rgba(52, 211, 153, 0);
    }
  }

  .hero-name {
    font-size: var(--step-hero);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin-bottom: 2rem;
  }
  .line {
    display: block;
    overflow: clip;
  }
  .line-inner {
    display: block;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--text);
    max-width: 24ch;
    line-height: 1.25;
    margin-bottom: 1.2rem;
  }
  .hero-tagline strong {
    color: var(--accent-bright);
    font-weight: 600;
  }

  .hero-sub {
    color: var(--text-muted);
    max-width: 52ch;
    margin-bottom: 2.6rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-faint);
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob {
    50% {
      transform: translate(-50%, 8px);
    }
  }
</style>
