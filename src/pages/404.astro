---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Guilherme Frazão" description="Page not found.">
  <section class="nf container">
    <p class="code accent-text">404</p>
    <h1>This page doesn't exist.</h1>
    <p class="sub">But plenty of other things here do.</p>
    <a class="btn btn-primary" href="/">Back home</a>
  </section>
</Base>

<style>
  .nf {
    min-height: 70svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.2rem;
    padding-top: 6rem;
  }
  .code {
    font-family: var(--font-display);
    font-size: var(--step-hero);
    font-weight: 700;
    line-height: 1;
  }
  h1 {
    font-size: var(--step-2);
  }
  .sub {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
</style>
