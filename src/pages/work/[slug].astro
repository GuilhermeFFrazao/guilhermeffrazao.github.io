---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('work');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const formatted = project.data.date.toLocaleDateString('en-GB', {
  month: 'long',
  year: 'numeric',
});
---

<Base title={`${project.data.title} — Guilherme Frazão`} description={project.data.summary}>
  <article class="case container">
    <header class="case-head">
      <a class="back link-draw" href="/#work">← Back to work</a>
      {project.data.status && <span class="status">{project.data.status}</span>}
      <h1>{project.data.title}</h1>
      <p class="summary">{project.data.summary}</p>
      <div class="meta">
        <span>{formatted}</span>
        <div class="tags">
          {project.data.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
        {project.data.github && (
          <a class="btn" href={project.data.github} target="_blank" rel="noopener">View on GitHub</a>
        )}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .case {
    padding-top: 9rem;
    max-width: 780px;
  }
  .back {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--step--1);
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }
  .status {
    display: block;
    width: fit-content;
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent-bright);
    border: 1px solid rgba(96, 165, 250, 0.35);
    border-radius: 999px;
    padding: 0.3em 0.9em;
    margin-bottom: 1.2rem;
  }
  h1 {
    font-size: var(--step-3);
    margin-bottom: 1rem;
  }
  .summary {
    color: var(--text-muted);
    font-size: var(--step-1);
    line-height: 1.5;
    margin-bottom: 1.8rem;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.2rem;
    font-family: var(--font-display);
    font-size: var(--step--1);
    color: var(--text-faint);
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .prose :global(h2) {
    font-size: var(--step-2);
    margin: 2.5rem 0 1rem;
  }
  .prose :global(h3) {
    font-size: var(--step-1);
    margin: 2rem 0 0.8rem;
  }
  .prose :global(p) {
    color: var(--text-muted);
    margin-bottom: 1.2rem;
  }
  .prose :global(strong) {
    color: var(--text);
  }
  .prose :global(ul),
  .prose :global(ol) {
    color: var(--text-muted);
    padding-left: 1.4rem;
    margin-bottom: 1.2rem;
    display: grid;
    gap: 0.5rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1rem 1.4rem;
    margin-bottom: 1.5rem;
  }
  .prose :global(blockquote p) {
    margin: 0;
  }
  .prose :global(code) {
    font-size: 0.9em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.15em 0.45em;
  }
  .prose :global(a) {
    color: var(--accent-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
